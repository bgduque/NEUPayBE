# Spring profile: dev | prod | test
SPRING_PROFILES_ACTIVE=dev

# --- Database (RDS / Aurora PostgreSQL) ----------------------------------
# In production point DB_HOST at the Aurora cluster endpoint.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neupayment
DB_USER=neupayment
DB_PASSWORD=change-me

# --- Security ------------------------------------------------------------
# Generate with: openssl rand -base64 96
NEU_JWT_SECRET=replace-with-a-real-base64-key-at-least-64-bytes

# Generate with: openssl rand -base64 48
NEU_QR_HMAC_SECRET=replace-with-a-real-base64-key-at-least-32-bytes

# Comma-separated origins. Use "*" only in dev.
NEU_CORS_ALLOWED_ORIGINS=https://neu.edu.ph
